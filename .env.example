# ───────────────────────────────────────────────────────────────
# CredFlow — Environment variables
# Copy to `.env` (root) before running with Docker Compose.
# ───────────────────────────────────────────────────────────────

# --- Database (PostgreSQL) ---
POSTGRES_USER=credflow
POSTGRES_PASSWORD=credflow_secret
POSTGRES_DB=credflow
# Host port to publish PostgreSQL on. Change if 5432 is already in use locally.
DB_PORT=5432
# Used by the API container (host = service name `db`)
DATABASE_URL=postgresql://credflow:credflow_secret@db:5432/credflow?schema=public
# Connection-pool + TLS tuning for the pg driver adapter (all optional). The
# adapter does NOT honor `?connection_limit=` from the URL, so size the pool here.
# DB_POOL_MAX is PER API process — keep (replicas × DB_POOL_MAX) under the
# server's max_connections.
#DB_POOL_MAX=10
#DB_STATEMENT_TIMEOUT_MS=30000
#DB_CONNECT_TIMEOUT_MS=10000
# TLS to the database. Defaults ON when NODE_ENV=production. For a managed DB set
# sslmode=require in DATABASE_URL too; for a self-signed cert add
# DB_SSL_REJECT_UNAUTHORIZED=false.
#DB_SSL=true

# --- API ---
NODE_ENV=development
API_PORT=3333
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:5173
# Express "trust proxy": set to the number of proxy hops (e.g. 1) when running
# behind a load balancer / reverse proxy, so req.ip is the real client (accurate
# per-IP throttling + audit). Leave empty/unset for direct exposure.
TRUST_PROXY=
# Access-log format: "json" (structured) or "pretty" (human-readable). Defaults
# to json in production and pretty otherwise. Leave empty to use the default.
LOG_FORMAT=

# --- Auth / JWT ---
# WARNING: DEV-ONLY placeholders. They let the stack boot with one command
# locally, but are REJECTED when NODE_ENV=production (see config/env.validation.ts).
# Generate unique secrets for any deployed environment:  openssl rand -hex 48
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars_long_value
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars_long_value
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# --- Field-level encryption (AES-256-GCM) for sensitive PII ---
# WARNING: DEV-ONLY key — also rejected when NODE_ENV=production. Must decode to
# exactly 32 bytes (base64, 44 chars). Generate for prod:  openssl rand -base64 32
ENCRYPTION_KEY=Z3vJ8mC2pQ9rS5tU7wX0yA1bD4eF6gH8iK0lM2nO4qQ=
# Optional dedicated key for the CPF/CNPJ blind index (HMAC-SHA256). When unset it
# is derived from ENCRYPTION_KEY via HKDF (domain-separated). Set an independent
# 32-byte base64 key for the strongest separation. Changing it requires re-running
# `npm run db:backfill-documents` to re-index existing rows. Generate: openssl rand -base64 32
BLIND_INDEX_KEY=

# --- Rate limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=120
# Optional: a Redis URL makes rate-limit counters shared across API replicas
# (required for correct throttling when running more than one instance).
# Example: redis://localhost:6379. Leave empty to use per-process in-memory.
THROTTLER_REDIS_URL=

# --- Observability ---
# Optional bearer token guarding GET /api/metrics (Prometheus). When set, a
# scraper must send `Authorization: Bearer <token>` (or `?token=`). Leave empty
# to keep /metrics public for local dev (restrict at the network layer in prod).
METRICS_TOKEN=

# --- Boot tasks (docker-entrypoint.sh) ---
SEED_ADMIN_EMAIL=admin@credflow.dev
SEED_ADMIN_PASSWORD=Admin@123456
# Apply migrations on boot. Set false on horizontally-scaled replicas and run
# `prisma migrate deploy` as a separate one-shot job so replicas don't race.
#RUN_MIGRATIONS=true
# Encrypt legacy plaintext documents on boot (idempotent). Defaults to RUN_MIGRATIONS.
#RUN_BACKFILL=true
# Seed demo data on boot. OFF by default (a production boot never seeds); this
# dev/demo .env opts in explicitly. A seed failure aborts boot.
RUN_SEED=true

# --- Web (frontend build) ---
VITE_API_URL=http://localhost:3333
